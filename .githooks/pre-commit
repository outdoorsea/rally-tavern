#!/bin/bash
# Pre-commit hook for Rally Tavern

echo "🔍 Running pre-commit checks..."

# Security scan on staged files
STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(yaml|yml|md|json)$')

if [[ -n "$STAGED" ]]; then
  for file in $STAGED; do
    # Quick injection check
    if grep -qi "ignore.*previous.*instruction\|system.*prompt\|you.*are.*now" "$file" 2>/dev/null; then
      echo "❌ Security issue in: $file"
      echo "   Possible prompt injection detected"
      exit 1
    fi
  done
fi

# Block sensitive data in private profiles
PROFILE_FILES=$(echo "$STAGED" | grep -E '^profiles/' || true)
if [[ -n "$PROFILE_FILES" ]]; then
  for file in $PROFILE_FILES; do
    # Public profiles (marked with "Visibility: PUBLIC") may include more detail
    if grep -q "Visibility: PUBLIC" "$file" 2>/dev/null; then
      # Public profiles: still block security, quality, constraints, context, PII
      if grep -qiE "^(security|quality|constraints|context|contributed_by|created_at|updated_at):" "$file" 2>/dev/null; then
        echo "❌ Profile privacy violation in PUBLIC profile: $file"
        echo "   Even public profiles must not include: security, quality, constraints,"
        echo "   context, contributed_by, or timestamps."
        exit 1
      fi
    else
      # Private profiles: block everything sensitive
      if grep -qiE "^(architecture|security|quality|constraints|context|repo|contributed_by|created_at|updated_at):" "$file" 2>/dev/null; then
        echo "❌ Profile privacy violation in: $file"
        echo "   Private profiles must only contain: id, name, description, facets, needs, tags"
        echo "   Add '# Visibility: PUBLIC' comment to allow architecture and repo fields."
        exit 1
      fi
    fi
  done
fi

# Validate YAML syntax (if yq available)
if command -v yq &>/dev/null; then
  for file in $STAGED; do
    if [[ "$file" =~ \.yaml$ ]]; then
      if ! yq '.' "$file" >/dev/null 2>&1; then
        echo "❌ Invalid YAML: $file"
        exit 1
      fi
    fi
  done
fi

echo "✓ Pre-commit checks passed"
